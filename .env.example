# development | production
VOICEOPS_ENVIRONMENT=development
VOICEOPS_PUBLIC_BASE_URL=http://localhost:8000

# Required in production. The deployed Container App should use managed identity.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_MODEL=your-model-name
AZURE_OPENAI_API_VERSION=
AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_AI_SEARCH_INDEX=voiceops-knowledge
AZURE_AI_SEARCH_SEMANTIC_CONFIG=default
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOS_DATABASE=voiceops
AZURE_COSMOS_CONTAINER=calls
AZURE_COMMUNICATION_ENDPOINT=https://your-resource.communication.azure.com
AZURE_COMMUNICATION_CALLBACK_URL=https://your-public-host/integrations/acs/events
AZURE_MEDIA_WEBSOCKET_URL=wss://your-public-host/media
AZURE_SPEECH_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com/
AZURE_SPEECH_REGION=

# Entra ID validation for the operator console/API.
ENTRA_ISSUER=
ENTRA_AUDIENCE=
